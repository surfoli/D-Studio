# ─── Required ────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: Supabase Auth ─────────────────────────────────
# Required only if you want email/GitHub login.
# Get these at: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Optional: E2B Sandbox ───────────────────────────────────
# Required for live code execution/preview in Build Mode.
# Get your key at: https://e2b.dev → Free Tier → API Keys
E2B_API_KEY=e2b_...

# ─── Optional: Vercel Deploy ─────────────────────────────────
# Required for 1-click Vercel deployment.
# Create a token at: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=team_...   # Only if deploying to a team

# ─── Optional: Model Override ────────────────────────────────
# Default: claude-sonnet-4-6 (recommended for speed + quality)
# ANTHROPIC_MODEL=claude-opus-4-6
